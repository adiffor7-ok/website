# Exclude dev-only or bulky paths from Vercel deployment (not whole galleries)
scripts/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
node_modules/

# Python virtual environments
venv/
env/
.venv/

# Git
.git/
.gitignore

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Ship data/*.json and data/documents.manifest.js; exclude local backup only
data/*.google-backup

# Never upload OAuth secrets with CLI deploy (belt-and-suspenders; also gitignored)
credentials.json
token.json
google-photos-credentials.json
